#!/usr/bin/env bash
# One-time initial setup for building zsh-wasm.
# Run from the project root after downloading zsh-5.9 source (see README step 1).
# Idempotent — safe to run again if a previous attempt was incomplete.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
STUB="$ROOT/ncurses-stub"
SRC="$ROOT/zsh-5.9"
BUILD="$ROOT/build-zsh"

if [[ ! -d "$SRC" ]]; then
    echo "Error: $SRC not found. Download it first:"
    echo "  curl -L -O https://www.zsh.org/pub/zsh-5.9.tar.xz && tar xf zsh-5.9.tar.xz"
    exit 1
fi

echo "==> building ncurses stub"
if [[ -f "$STUB/lib/libncurses.a" ]]; then
    echo "    already built, skipping"
else
    cd "$STUB"
    emcc -c ncurses_stub.c -o ncurses_stub.o
    emar rcs lib/libncurses.a ncurses_stub.o
    cd "$ROOT"
fi

echo "==> patching zsh source"
# zutil.mdd: remove spurious moddeps on zsh/complete
if grep -q 'moddeps="zsh/complete"' "$SRC/Src/Modules/zutil.mdd" 2>/dev/null; then
    sed -i '' '/^moddeps="zsh\/complete"$/d' "$SRC/Src/Modules/zutil.mdd"
    echo "    zutil.mdd: removed moddeps line"
else
    echo "    zutil.mdd: already patched"
fi
# zutil.c: inline the one call that depended on zsh/complete
if grep -q 'set_list_array(args\[1\], zstyle_list)' "$SRC/Src/Modules/zutil.c"; then
    sed -i '' \
        's/set_list_array(args\[1\], zstyle_list);/setaparam(args[1], zlinklist2array(zstyle_list, 1));/' \
        "$SRC/Src/Modules/zutil.c"
    echo "    zutil.c: inlined set_list_array call"
else
    echo "    zutil.c: already patched"
fi

# exec.c: add no-fork fallback for $() command substitution in wasm
if grep -q '__EMSCRIPTEN__' "$SRC/Src/exec.c"; then
    echo "    exec.c: already patched for wasm command substitution"
else
    python3 - "$SRC/Src/exec.c" << 'PYEOF'
import sys
with open(sys.argv[1]) as f:
    src = f.read()
OLD_ZFORK = (
    '    if (pid == -1) {\n'
    '\tzerr("fork failed: %e", errno);\n'
    '\treturn -1;\n'
    '    }'
)
NEW_ZFORK = (
    '    if (pid == -1) {\n'
    '#ifdef __EMSCRIPTEN__\n'
    '\tif (errno == ENOSYS)\n'
    '\t    return -1;\t/* fork() unavailable in wasm \xe2\x80\x94 caller handles this silently */\n'
    '#endif\n'
    '\tzerr("fork failed: %e", errno);\n'
    '\treturn -1;\n'
    '    }'
)
if OLD_ZFORK in src:
    src = src.replace(OLD_ZFORK, NEW_ZFORK, 1)
elif NEW_ZFORK in src:
    pass  # already patched
else:
    print('ERROR: could not find zfork error block in exec.c', file=__import__('sys').stderr)
    raise SystemExit(1)
OLD = (
    '    if ((cmdoutpid = pid = zfork(NULL)) == -1) {\n'
    '\t/* fork error */\n'
    '\tzclose(pipes[0]);\n'
    '\tzclose(pipes[1]);\n'
    '\terrflag |= ERRFLAG_ERROR;\n'
    '\tcmdoutpid = 0;\n'
    '\tchild_unblock();\n'
    '\treturn NULL;\n'
    '    } else if (pid) {'
)
NEW = (
    '    if ((cmdoutpid = pid = zfork(NULL)) == -1) {\n'
    '\t/* fork error */\n'
    '#ifdef __EMSCRIPTEN__\n'
    '\t/* Wasm: fork() is unavailable; run the substituted command in-process.\n'
    '\t * Variable assignments inside $() leak to the parent shell.\n'
    '\t * Output larger than the pipe buffer may deadlock; both are acceptable\n'
    '\t * for the script workloads zsh-wasm targets. */\n'
    '\t{\n'
    '\t\tLinkList retval;\n'
    '\t\tint oldout = dup(1);\n'
    '\t\tif (oldout == -1 || dup2(pipes[1], 1) == -1) {\n'
    '\t\t\tif (oldout != -1) close(oldout);\n'
    '\t\t\tzclose(pipes[0]);\n'
    '\t\t\tzclose(pipes[1]);\n'
    '\t\t\terrflag |= ERRFLAG_ERROR;\n'
    '\t\t\tcmdoutpid = 0;\n'
    '\t\t\tchild_unblock();\n'
    '\t\t\treturn NULL;\n'
    '\t\t}\n'
    '\t\tzclose(pipes[1]);\n'
    '\t\terrflag = 0;\n'
    '\t\tcmdoutpid = 0;\n'
    '\t\tcmdpush(CS_CMDSUBST);\n'
    '\t\texecode(prog, 0, 1, "cmdsubst");\n'
    '\t\tcmdpop();\n'
    '\t\tcmdoutval = lastval;\n'
    '\t\tfflush(stdout);\n'
    '\t\tdup2(oldout, 1);\n'
    '\t\tclose(oldout);\n'
    '\t\tchild_unblock();\n'
    '\t\terrflag = 0;\t/* discard fork-failure errflag; errors are in cmdoutval */\n'
    '\t\tretval = readoutput(pipes[0], qt, NULL);\n'
    '\t\tfdtable[pipes[0]] = FDT_UNUSED;\n'
    '\t\tlastval = cmdoutval;\n'
    '\t\treturn retval;\n'
    '\t}\n'
    '#endif\n'
    '\tzclose(pipes[0]);\n'
    '\tzclose(pipes[1]);\n'
    '\terrflag |= ERRFLAG_ERROR;\n'
    '\tcmdoutpid = 0;\n'
    '\tchild_unblock();\n'
    '\treturn NULL;\n'
    '    } else if (pid) {'
)
if OLD not in src:
    print('ERROR: could not find fork-error block in exec.c', file=__import__('sys').stderr)
    raise SystemExit(1)
with open(sys.argv[1], 'w') as f:
    f.write(src.replace(OLD, NEW, 1))
PYEOF
    echo "    exec.c: patched for wasm command substitution"
fi

echo "==> configuring"
if [[ -f "$BUILD/Makefile" ]]; then
    echo "    already configured (delete build-zsh/ to reconfigure from scratch)"
else
    mkdir -p "$BUILD"
    cd "$BUILD"
    emconfigure "$SRC/configure" \
        --build="$("$SRC/config.guess")" \
        --host=wasm32-unknown-emscripten \
        --disable-dynamic \
        --without-tcsetpgrp \
        --disable-dynamic-nss \
        CPPFLAGS="-I$STUB/include" \
        LDFLAGS="-L$STUB/lib" \
        LIBS="-lncurses" \
        CFLAGS="-Os"
    cd "$ROOT"
fi

echo "==> patching config.h"
"$ROOT/bin/patch-config"

echo "==> patching generated build files"
cd "$BUILD"
if grep -q '^ZSH_TERM_H = term.h' Config/defs.mk; then
    echo "    defs.mk: already patched"
else
    sed -i '' 's/^ZSH_TERM_H = $/ZSH_TERM_H = term.h/' Config/defs.mk
    echo "    defs.mk: patched"
fi
if [[ -f Src/zshterm.h ]] && grep -q 'term.h' Src/zshterm.h; then
    echo "    zshterm.h: already exists"
else
    printf '#include <term.h>\n' > Src/zshterm.h
    echo "    zshterm.h: created"
fi

echo "==> configuring modules"
# Disable ZLE/completion — require a real terminal and add ~350KB to the binary
sed -i '' -E \
    -e 's/^(name=zsh\/(zle|compctl|complete|complist|computil|zleparameter) .*)link=static/\1link=no/' \
    -e 's/^(name=zsh\/(zle|compctl|complete|complist|computil|zleparameter) .*)load=yes/\1load=no/' \
    config.modules
# Enable zsh/files (file ops without fork) and zsh/stat (file metadata for ls -l)
sed -i '' -E \
    -e 's/^(name=zsh\/(files|stat) .*)link=no/\1link=static/' \
    -e 's/^(name=zsh\/(files|stat) .*)load=no/\1load=yes/' \
    config.modules
# Enable zsh/regex so that [[ str =~ pat ]] works.
# regex.mdd only emits link=dynamic or link=no; since we build --disable-dynamic
# the module would otherwise be compiled out, causing =~ to abort the script via
# errflag when ensurefeature("zsh/regex") fails at runtime.
# HAVE_REGCOMP/HAVE_REGEXEC are already 1 in config.h (musl libc provides them).
sed -i '' -E \
    -e 's/^(name=zsh\/regex .*)link=no/\1link=static/' \
    -e 's/^(name=zsh\/regex .*)load=no/\1load=yes/' \
    config.modules
# Register zsh/sed (disabled by default; enabled at build time with --with-sed).
# The module descriptor lives in sed-src/; bin/build --with-sed copies it to the
# zsh source tree before compiling.  We just need the entry in config.modules so
# that bin/build can flip link=static when requested.
if grep -q '^name=zsh/sed ' config.modules; then
    echo "    config.modules: zsh/sed already present"
else
    sed -i '' '/^name=zsh\/net\/socket /a\
name=zsh/sed modfile=Src/Modules/sed.mdd link=no auto=yes load=no' \
        config.modules
    echo "    config.modules: added zsh/sed (disabled by default)"
fi
# Patch config.modules.sh so the zsh/sed entry survives a manual config.status run.
if grep -q 'zsh/sed' config.modules.sh; then
    echo "    config.modules.sh: zsh/sed already present"
else
    sed -i '' '/\*" zsh\/stat "\*) grep/i\
case "$userlist" in\
  *" zsh\/sed "*) grep "^name=zsh\/sed " ${CONFIG_MODULES}.old;;\
  *) echo "name=zsh\/sed modfile=Src\/Modules\/sed.mdd link=no auto=yes load=no";;\
esac' \
        config.modules.sh
    echo "    config.modules.sh: added zsh/sed entry"
fi
echo "    config.modules: done"

echo ""
echo "Setup complete. Run  bin/build  to compile and deploy."
