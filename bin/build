#!/usr/bin/env bash
# Rebuilds zsh.wasm from the configured build-zsh/ tree and deploys it.
#
# Usage: bin/build [--debug] [--out DIR] [--with-sed] [--with-awk]
#
#   --debug      Compile with -O0 -g instead of -Os, and link with
#                -sASSERTIONS=1 -gsource-map. Produces a larger build with
#                readable stack traces in browser devtools. Never ship this.
#   --out DIR    Deploy zsh.js and zsh.wasm to DIR instead of web/
#                (useful when building for an npm package or other output target)
#   --with-sed   Compile OpenBSD sed into the wasm binary as a `sed` builtin
#                (~50–100 KB increase). Requires sed-src/ in the project root.
#   --with-awk   Compile one-true-awk into the wasm binary as an `awk` builtin
#                (~150–200 KB increase). Requires awk-src/ in the project root.
#
# Prerequisites (one-time setup — see README):
#   1. zsh-5.9/ source directory
#   2. ncurses-stub built  (bin/setup handles this)
#   3. build-zsh/ configured via emconfigure  (bin/setup handles this)
#   4. zutil.mdd / zutil.c source patches applied  (bin/setup handles this)
#
# After bin/setup, just run:   bin/build
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BUILD="$ROOT/build-zsh"
STUB="$ROOT/ncurses-stub"
ORIG_DIR="$(pwd)"

DEBUG=0
OUT_DIR="$ROOT/web"
WITH_SED=0
WITH_AWK=0

while (( $# )); do
    case $1 in
        --debug)    DEBUG=1 ;;
        --with-sed) WITH_SED=1 ;;
        --with-awk) WITH_AWK=1 ;;
        --out)      shift; OUT_DIR=$1 ;;
        --out=*)    OUT_DIR=${1#--out=} ;;
        *)          echo "Unknown option: $1" >&2; exit 1 ;;
    esac
    shift
done

# Resolve a relative --out path against the caller's working directory,
# not build-zsh/ (where we cd below).
[[ "$OUT_DIR" != /* ]] && OUT_DIR="$ORIG_DIR/$OUT_DIR"

# Determine build flags first — used by both the sed pre-compilation and emmake.
if (( DEBUG )); then
    BUILD_CFLAGS="-O0 -g"
    EXTRA_LDFLAGS="-sASSERTIONS=1 -gsource-map"
    echo "==> build mode: debug (-O0 -g -sASSERTIONS=1 -gsource-map)"
else
    BUILD_CFLAGS="-Os"
    EXTRA_LDFLAGS=""
fi

cd "$BUILD"

echo "==> make prep (regenerates Makefiles from config.modules)"
emmake make prep

# make prep re-runs config.status which can regenerate config.modules from the
# .mdd files, resetting module link= flags.  Re-apply our overrides every time.
echo "==> patching config.modules"
sed -i '' -E \
    -e 's/^(name=zsh\/(zle|compctl|complete|complist|computil|zleparameter) .*)link=static/\1link=no/' \
    -e 's/^(name=zsh\/(zle|compctl|complete|complist|computil|zleparameter) .*)load=yes/\1load=no/' \
    -e 's/^(name=zsh\/(files|stat|regex) .*)link=no/\1link=static/' \
    -e 's/^(name=zsh\/(files|stat|regex) .*)load=no/\1load=yes/' \
    -e 's/^(name=zsh\/sed .*)link=static/\1link=no/' \
    -e 's/^(name=zsh\/sed .*)load=yes/\1load=no/' \
    -e 's/^(name=zsh\/awk .*)link=static/\1link=no/' \
    -e 's/^(name=zsh\/awk .*)load=yes/\1load=no/' \
    config.modules

# Compile and enable zsh/sed if requested.
# sed-src/ files are compiled separately (they live outside the zsh source
# tree); the resulting .o files are injected at link time via LDFLAGS, and
# -I sed-src is added to CFLAGS so sed.c (the zsh module glue) can find
# sed_embed.h.
SED_CFLAGS=""
SED_LDFLAGS=""
SED_SRC="$ROOT/sed-src"
SED_BUILD="$ROOT/build-sed"
if (( WITH_SED )); then
    echo "==> enabling zsh/sed"

    # zsh-5.9/ is not tracked in git; place the module descriptor there so
    # mkbltnmlst.sh can source it during the build.
    cp "$SED_SRC/sed.mdd" "$ROOT/zsh-5.9/Src/Modules/sed.mdd"

    # Ensure zsh/sed is in config.modules; add with link=no as the default
    # state (the patch below will then flip it to link=static for this build).
    if ! grep -q '^name=zsh/sed ' config.modules; then
        # Insert after zsh/net/socket line, preserving alphabetical order
        sed -i '' '/^name=zsh\/net\/socket /a\
name=zsh/sed modfile=Src/Modules/sed.mdd link=no auto=yes load=no' \
            config.modules
    fi
    sed -i '' -E \
        -e 's/^(name=zsh\/sed .*)link=no/\1link=static/' \
        -e 's/^(name=zsh\/sed .*)load=no/\1load=yes/' \
        config.modules

    # Place the generated module header and prototype file in the build tree.
    # These are normally generated by the Makefile from sed.mdd, but since we
    # bypass the Makefile for this module we provide them directly.
    if [[ ! -f "$BUILD/Src/Modules/sed.epro" ]]; then
        cat > "$BUILD/Src/Modules/sed.epro" <<'EPRO'
/* Generated automatically */
#ifndef have_Src_Modules_sed_globals
#define have_Src_Modules_sed_globals

extern int setup_ _((UNUSED(Module m)));
extern int features_ _((Module m,char***features));
extern int enables_ _((Module m,int**enables));
extern int boot_ _((UNUSED(Module m)));
extern int cleanup_ _((Module m));
extern int finish_ _((UNUSED(Module m)));

#endif /* !have_Src_Modules_sed_globals */
EPRO
    fi
    if [[ ! -f "$BUILD/Src/Modules/sed.mdh" ]]; then
        cat > "$BUILD/Src/Modules/sed.mdh" <<'MDH'
#ifndef have_zshQssed_module
#define have_zshQssed_module

# ifndef IMPORTING_MODULE_zshQssed
#   define boot_ boot_zshQssed
#   define cleanup_ cleanup_zshQssed
#   define features_ features_zshQssed
#   define enables_ enables_zshQssed
#   define setup_ setup_zshQssed
#   define finish_ finish_zshQssed
# endif /* !IMPORTING_MODULE_zshQssed */

/* Module dependencies */
# define IMPORTING_MODULE_zshQsmain 1
# include "../../Src/zsh.mdh"

# undef mod_import_variable
# undef mod_import_function
# if defined(IMPORTING_MODULE_zshQssed) &&  defined(MODULE)
#  define mod_import_variable
#  define mod_import_function
# else
#  define mod_import_function
#  define mod_import_variable
# endif /* IMPORTING_MODULE_zshQssed && MODULE */
# include "sed.epro"
# undef mod_import_variable
# define mod_import_variable
# undef mod_import_variable
# define mod_import_variable
# ifndef mod_export
#  define mod_export
# endif /* mod_export */

#endif /* !have_zshQssed_module */
MDH
    fi

    mkdir -p "$SED_BUILD"

    echo "==> compiling sed-src/"
    # Source filename differs from the object name we want to produce
    declare -A SED_FILE=(
        [sed_embed]="$SED_SRC/sed_embed.c"
        [sed_main]="$SED_SRC/main.c"
        [sed_compile]="$SED_SRC/compile.c"
        [sed_misc]="$SED_SRC/misc.c"
        [sed_process]="$SED_SRC/process.c"
    )
    for name in sed_embed sed_main sed_compile sed_misc sed_process; do
        emcc $BUILD_CFLAGS -c "${SED_FILE[$name]}" \
            -o "$SED_BUILD/$name.o" \
            -I"$SED_SRC"
    done

    # Compile the zsh module glue (sed_mod.c lives in sed-src/, not in the zsh
    # source tree, so the Makefile never sees it).  Include paths mirror the
    # COMPILE variable in Src/Modules/Makefile.
    echo "==> compiling zsh/sed module glue"
    emcc $BUILD_CFLAGS -c "$SED_SRC/sed_mod.c" \
        -o "$SED_BUILD/sed_mod.o" \
        -I"$BUILD/Src/Modules" \
        -I"$BUILD/Src" \
        -I"$ROOT/zsh-5.9/Src" \
        -I"$ROOT/zsh-5.9/Src/Zle" \
        -I"$ROOT/zsh-5.9/Src/Modules" \
        -I"$STUB/include" \
        -I"$SED_SRC" \
        -DHAVE_CONFIG_H

    SED_CFLAGS="-I$SED_SRC"
    SED_LDFLAGS="$SED_BUILD/sed_mod.o \
        $SED_BUILD/sed_embed.o $SED_BUILD/sed_main.o \
        $SED_BUILD/sed_compile.o $SED_BUILD/sed_misc.o $SED_BUILD/sed_process.o"
fi

AWK_CFLAGS=""
AWK_LDFLAGS=""
AWK_SRC="$ROOT/awk-src"
AWK_BUILD="$ROOT/build-awk"
if (( WITH_AWK )); then
    echo "==> enabling zsh/awk"

    cp "$AWK_SRC/awk.mdd" "$ROOT/zsh-5.9/Src/Modules/awk.mdd"

    if ! grep -q '^name=zsh/awk ' config.modules; then
        sed -i '' '/^name=zsh\/net\/socket /a\
name=zsh/awk modfile=Src/Modules/awk.mdd link=no auto=yes load=no' \
            config.modules
    fi
    sed -i '' -E \
        -e 's/^(name=zsh\/awk .*)link=no/\1link=static/' \
        -e 's/^(name=zsh\/awk .*)load=no/\1load=yes/' \
        config.modules

    if [[ ! -f "$BUILD/Src/Modules/awk.epro" ]]; then
        cat > "$BUILD/Src/Modules/awk.epro" <<'EPRO'
/* Generated automatically */
#ifndef have_Src_Modules_awk_globals
#define have_Src_Modules_awk_globals

extern int setup_ _((UNUSED(Module m)));
extern int features_ _((Module m,char***features));
extern int enables_ _((Module m,int**enables));
extern int boot_ _((UNUSED(Module m)));
extern int cleanup_ _((Module m));
extern int finish_ _((UNUSED(Module m)));

#endif /* !have_Src_Modules_awk_globals */
EPRO
    fi
    if [[ ! -f "$BUILD/Src/Modules/awk.mdh" ]]; then
        cat > "$BUILD/Src/Modules/awk.mdh" <<'MDH'
#ifndef have_zshQsawk_module
#define have_zshQsawk_module

# ifndef IMPORTING_MODULE_zshQsawk
#   define boot_ boot_zshQsawk
#   define cleanup_ cleanup_zshQsawk
#   define features_ features_zshQsawk
#   define enables_ enables_zshQsawk
#   define setup_ setup_zshQsawk
#   define finish_ finish_zshQsawk
# endif /* !IMPORTING_MODULE_zshQsawk */

/* Module dependencies */
# define IMPORTING_MODULE_zshQsmain 1
# include "../../Src/zsh.mdh"

# undef mod_import_variable
# undef mod_import_function
# if defined(IMPORTING_MODULE_zshQsawk) &&  defined(MODULE)
#  define mod_import_variable
#  define mod_import_function
# else
#  define mod_import_function
#  define mod_import_variable
# endif /* IMPORTING_MODULE_zshQsawk && MODULE */
# include "awk.epro"
# undef mod_import_variable
# define mod_import_variable
# undef mod_import_variable
# define mod_import_variable
# ifndef mod_export
#  define mod_export
# endif /* mod_export */

#endif /* !have_zshQsawk_module */
MDH
    fi

    mkdir -p "$AWK_BUILD"

    echo "==> compiling awk-src/"
    AWK_OBJS=(
        awk_embed awk_main awk_lib awk_run awk_tran
        awk_parse awk_lex awk_b awk_proctab awk_awkgram
    )
    declare -A AWK_FILE=(
        [awk_embed]="$AWK_SRC/awk_embed.c"
        [awk_main]="$AWK_SRC/main.c"
        [awk_lib]="$AWK_SRC/lib.c"
        [awk_run]="$AWK_SRC/run.c"
        [awk_tran]="$AWK_SRC/tran.c"
        [awk_parse]="$AWK_SRC/parse.c"
        [awk_lex]="$AWK_SRC/lex.c"
        [awk_b]="$AWK_SRC/b.c"
        [awk_proctab]="$AWK_SRC/proctab.c"
        [awk_awkgram]="$AWK_SRC/awkgram.tab.c"
    )
    # Rename globals that conflict with zsh or sed symbols at link time.
    AWK_RENAME="-Dinfile=awk_infile -Dinnew=awk_innew -Dmatch=awk_match -Dlineno=awk_lineno -Derror=awk_error"
    for name in "${AWK_OBJS[@]}"; do
        emcc $BUILD_CFLAGS -c "${AWK_FILE[$name]}" \
            -o "$AWK_BUILD/$name.o" \
            -I"$AWK_SRC" \
            $AWK_RENAME \
            -Wno-implicit-function-declaration \
            -Wno-unused-result
    done

    echo "==> compiling zsh/awk module glue"
    emcc $BUILD_CFLAGS -c "$AWK_SRC/awk_mod.c" \
        -o "$AWK_BUILD/awk_mod.o" \
        -I"$BUILD/Src/Modules" \
        -I"$BUILD/Src" \
        -I"$ROOT/zsh-5.9/Src" \
        -I"$ROOT/zsh-5.9/Src/Zle" \
        -I"$ROOT/zsh-5.9/Src/Modules" \
        -I"$STUB/include" \
        -I"$AWK_SRC" \
        -DHAVE_CONFIG_H

    AWK_CFLAGS="-I$AWK_SRC"
    AWK_LDFLAGS="$AWK_BUILD/awk_mod.o"
    for name in "${AWK_OBJS[@]}"; do
        AWK_LDFLAGS+=" $AWK_BUILD/$name.o"
    done
fi

echo "==> patching config.h"
"$ROOT/bin/patch-config"

echo "==> building"
emmake make \
    CFLAGS="$BUILD_CFLAGS $SED_CFLAGS $AWK_CFLAGS" \
    LDFLAGS="-L$STUB/lib \
        -sFORCE_FILESYSTEM=1 \
        -sEXPORTED_RUNTIME_METHODS=FS,callMain,IDBFS \
        -sMODULARIZE=1 \
        -sEXPORT_NAME=createZshModule \
        -lidbfs.js \
        $EXTRA_LDFLAGS \
        $SED_LDFLAGS \
        $AWK_LDFLAGS"

echo "==> deploying to $OUT_DIR"
mkdir -p "$OUT_DIR"
cp Src/zsh      "$OUT_DIR/zsh.js"
cp Src/zsh.wasm "$OUT_DIR/zsh.wasm"
if (( DEBUG )) && [[ -f Src/zsh.wasm.map ]]; then
    cp Src/zsh.wasm.map "$OUT_DIR/zsh.wasm.map"
fi

# When deploying outside web/, also copy the runtime JS files that live there.
if [[ "$OUT_DIR" != "$ROOT/web" ]]; then
    cp "$ROOT/web/zsh-runtime.js" "$OUT_DIR/zsh-runtime.js"
    cp "$ROOT/web/zsh-worker.js"  "$OUT_DIR/zsh-worker.js"
fi

SIZE=$(du -h "$OUT_DIR/zsh.wasm" | cut -f1)
echo "Done — $OUT_DIR/zsh.wasm is $SIZE"
